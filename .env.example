DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_intelligence"
NODE_ENV="development"
AUTH_SECRET="local-dev-secret"
OPERATOR_USERNAME="operator"
OPERATOR_PASSWORD="change-me"

# Real-time data source keys (optional - without these the system uses demo data)
# Get API-Football key: https://www.api-football.com
API_FOOTBALL_KEY=""
# Get The Odds API key: https://the-odds-api.com
THE_ODDS_API_KEY=""

# Cron / GitHub Actions shared secret
CRON_REFRESH_TOKEN="local-cron-token"
