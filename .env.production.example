DATABASE_URL="postgresql://username:password@host:5432/football_intelligence"
NODE_ENV="production"
AUTH_SECRET="replace-with-long-random-secret-at-least-32-chars"
OPERATOR_USERNAME="operator"
OPERATOR_PASSWORD="replace-with-strong-password"

# Real-time data source keys (optional - without these the system uses demo data)
# Get API-Football key: https://www.api-football.com (free tier: 100 req/day)
API_FOOTBALL_KEY="your-api-football-key-here"
# Get The Odds API key: https://the-odds-api.com (free tier: 500 req/month)
THE_ODDS_API_KEY="your-the-odds-api-key-here"

# Wikipedia rankings and RSS news are public, no key required.

# Cron / GitHub Actions shared secret for /api/cron/refresh
CRON_REFRESH_TOKEN="generate-with-openssl-rand-hex-32"
